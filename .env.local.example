# 로컬 dev: uvicorn 기본 PORT 9000 (household-back/.env 의 PORT 기본값)
# 도커: docker-compose.yml 의 environment 가 BACKEND_URL=http://household-back:8000 으로 override
BACKEND_URL=http://localhost:9000

# 브라우저는 nginx 리버스 프록시 통과 (same-origin /api/*) — 별도 노출 URL 불필요
# NEXT_PUBLIC_BACKEND_URL=

# 추후 클라이언트에서 JWT 검증 필요 시 사용 (현재 미사용)
# AUTH_SECRET=
